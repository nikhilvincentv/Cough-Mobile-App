{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "train": "python3 training/train_coswara.py",
    "train:coughsense": "python3 ml_service/train_coughsense.py --use_csv --csv_path ml_service/local_data.csv",
    "train:v4": "python3 -u ml_service/train_v4.py --csv ml_service/full_data.csv --output_dir checkpoints_v4 --epochs 60 --batch_size 16 --folds 5",
    "build:dataset": "python3 ml_service/build_full_dataset.py",
    "setup:data": "python3 ml_service/setup_data.py",
    "ml": "python3 ml_service/coughsense_service.py"
  },
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "@neondatabase/serverless": "^1.0.2",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.9",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.0",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.52.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
