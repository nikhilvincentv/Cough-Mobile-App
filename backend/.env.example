# CoughSense Backend — environment variables
# Copy to .env and fill in values

# Path to Coswara TRANSFER folders (defaults to ~/Downloads)
COSWARA_ROOT=/path/to/downloads

# Flask config
FLASK_ENV=development
FLASK_PORT=5000

# Model checkpoint to load for inference
MODEL_CHECKPOINT=checkpoints_v4/fold1_best.pt

# MPS / CUDA device selection (auto, cpu, mps, cuda)
DEVICE=auto
